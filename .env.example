# Santana — Configuration minimale
# Provider LLM principal : DeepSeek (voir soul/SOUL.md — "frugalité, DeepSeek Flash").
# Obtenir une clé : https://platform.deepseek.com/

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=votre_token_telegram
CHAT_ID=votre_chat_id

# ── DeepSeek — provider principal ───────────────────────────────────────────
DEEPSEEK_API_KEY=votre_cle_deepseek
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Groq — fallback unique ─────────────────────────────────────────────────
# GROQ_API_KEY=votre_cle_groq
GROQ_MODEL=llama-3.3-70b-versatile

# ── Budget ────────────────────────────────────────────────────────────────
DEEPSEEK_COST_LIMIT=0.10
DEEPSEEK_PRICE_PER_1M_USD=0.14

# ── Accès ─────────────────────────────────────────────────────────────────
# GROUP_BLACK_INTELLIGENCE=votre_chat_id_autorise
